{
  "tesserae_compat": "1.x",
  "name": "PicPak client (2-bpp BWRY .bin)",
  "version": "0.2.0",
  "description": "Composition PNG dithered to the PicPak 4-colour panel (Black/White/Yellow/Red) and packed into the 2-bpp, 30000-byte buffer the PicPak custom firmware streams to SPI. Published retained to tesserae/picpak/frame/bin.",
  "orientation": "composition",
  "mime": "application/octet-stream",
  "extension": "bin",
  "topic_pattern": "tesserae/{device}/frame/bin",
  "device": "picpak",
  "retain": true,
  "settings": [
    {
      "name": "dither",
      "type": "select",
      "label": "Dither mode",
      "default": "floyd-steinberg",
      "device_setting": true,
      "choices": [
        { "value": "floyd-steinberg", "label": "Floyd-Steinberg (smooth gradients)" },
        { "value": "atkinson", "label": "Atkinson (contrasty, clean solids)" },
        { "value": "jarvis", "label": "Jarvis-Judice-Ninke (smoothest)" },
        { "value": "stucki", "label": "Stucki" },
        { "value": "bayer-8x8", "label": "Bayer 8x8 (ordered)" },
        { "value": "halftone", "label": "Halftone dots" },
        { "value": "crosshatch", "label": "Crosshatch" },
        { "value": "none", "label": "None (snap to palette)" }
      ]
    },
    {
      "name": "saturation",
      "type": "slider",
      "label": "Pre-quantise saturation",
      "default": 1.0,
      "min": 0,
      "max": 3,
      "step": 0.05,
      "device_setting": true
    },
    {
      "name": "contrast",
      "type": "slider",
      "label": "Pre-quantise contrast",
      "default": 1.0,
      "min": 0,
      "max": 3,
      "step": 0.05,
      "device_setting": true
    }
  ]
}
